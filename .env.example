# Copy this to .env and fill in values. Never commit .env.

# --- LLM inference (Groq free tier) ---
GROQ_API_KEY=

# --- Tracing (Langfuse free tier) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Vector store (pgvector — Neon/Supabase free tier) ---
DATABASE_URL=postgresql://user:password@host:5432/trialguard

# --- Condition scope ---
CONDITION_CLASS=oncology

# --- ClinicalTrials.gov API (no auth needed — left for reference) ---
CTGOV_API_BASE=https://clinicaltrials.gov/api/v2

# --- Hugging Face (for HF Spaces deploy) ---
HF_TOKEN=
